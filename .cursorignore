# Rust / Tauri build artifacts
/target/
/ui/src-tauri/target/
/generated/**/target/
/generated/**/bin/
/generated/**/obj/

# Frontend dependencies and build output
/ui/node_modules/
/ui/dist/
/ui/dist-ssr/

# Generated code (output of this tool, not source)
/generated/

# Personal notes (also in .gitignore)
/private/

# Vendored mavlink repo — keep only XML definitions used by the generator
/mavlink/**
!mavlink/message_definitions/
!mavlink/message_definitions/**

# Tauri auto-generated schemas
/ui/src-tauri/gen/

# Logs and local overrides
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.local

# Compiled binaries and object files
*.exe
*.dll
*.so
*.dylib
*.rlib
*.o
*.obj
*.pdb

# Editor and OS junk
.DS_Store
.idea/
.vscode/
*.suo
*.sw?
